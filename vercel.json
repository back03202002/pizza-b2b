{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.pizza-b2b.com"
        }
      ],
      "destination": "https://pizza-b2b.com/$1",
      "permanent": true
    }
  ]
}